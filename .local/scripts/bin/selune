#! /usr/bin/env bash

SCRIPT_NAME=selune.sh
SCRIPT_PATH="$PWD/$SCRIPT_NAME"
FUNC_REGEX='[a-zA-Z]+[a-zA-Z0-9_-]*\(\)'

selune_exists() {
  [ -f "$SCRIPT_PATH" ]
}

stderr() {
  echo "$*" 1>&2
}

usage() {
  cat - <<EOF
Poor-man's Makefile runner.
Write your functions in bash (in a selune.sh file) and just called them like this \`selune do_something\`.
I wrote this just so I didn't have to type ./ in every script, that's it.

Usage:
  $ selune [<cmd>] [...<args for cmd>]

Example:
  $ cat selune.sh
  test() { # Some help message here
    mix test && echo done
  }
  $ selune test
  # ... mix test output ...
  $ selune # opens up fzf, each entry displays the doc comment like this: \`test # Some help message\`
EOF
  exit 1
}

query=()
args=()
while true; do
  [ -z "$1" ] && break

  case "$1" in
    --help|-h|help)
      usage
      ;;

    *)
      if [ "${#query[@]}" -eq 0 ]; then
        query=( -1 -q "$1" )
      else
        args+=( "$1" )
      fi
      ;;
  esac

  shift
done

if ! selune_exists; then
  stderr "$SCRIPT_NAME not found / not executable."
  exit 0
fi

selune_functions=$(grep --extended-regexp "$FUNC_REGEX" "$SCRIPT_PATH" | grep -v "^__" | sed -e 's|()||g' -e 's|\s*{\s*||' -e 's|#\s*|#|' | awk -F'#' '{if ($2 != "") { printf "%s\t\t\t# %s\n", $1, $2} else {print $1}}')
if [ -z "$selune_functions" ]; then
  stderr "No functions found in $SCRIPT_NAME. Regex: $FUNC_REGEX"
  exit 0
fi

export FZF_DEFAULT_OPTS="$FZF_DEFAULT_OPTS --height=10"
source "$SCRIPT_PATH" || exit

title="${SELUNE_TITLE:-Run a function}"
func=$(echo "$selune_functions" | fzf "${query[@]}" --height=10 --nth=1 --ghost="$title" | awk -F'#' '{gsub(/[ \t]*/, "", $1); print $1}') || exit
[ -z "$func" ] && exit 1

"$func" "${args[@]}"
