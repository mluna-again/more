{
  "$schema": "https://opencode.ai/tui.json",
  "scroll_speed": 3,
  "scroll_acceleration": {
    "enabled": true
  },
  "diff_style": "auto",
  "theme": "kanagawa-dragon",
  "keybinds": {
    "leader": "ctrl+k",
    "agent_list": "tab",
    "command_list": "<leader>p",
    "history_previous": "ctrl+p",
    "history_next": "ctrl+n"
  }
}
