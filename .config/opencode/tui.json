{
  "$schema": "https://opencode.ai/tui.json",
  "scroll_speed": 3,
  "scroll_acceleration": {
    "enabled": true
  },
  "diff_style": "auto",
  "theme": "kanagawa-dragon",
  "keybinds": {
    "leader": "ctrl+k",
    "agent_list": "tab",
    "command_list": "<leader>p",
    "history_previous": "ctrl+p",
    "history_next": "ctrl+n",
    "messages_half_page_up": "ctrl+u",
    "messages_half_page_down": "ctrl+d",
    "history_previous": "ctrl+p",
    "history_next": "ctrl+n",
    "messages_half_page_up": "ctrl+u",
    "messages_half_page_down": "ctrl+d",
    "messages_first": "ctrl+g",
    "messages_last": "ctrl+a"
  }
}
